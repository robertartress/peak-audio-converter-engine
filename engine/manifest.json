  "patches": [
    {
      "target": "libvorbis",
      "description": "Remove -mno-ieee-fp from the autotools configure script; emscripten clang rejects this flag.",
      "command": "sed -i 's/-mno-ieee-fp//g' configure"
    },
    {
      "target": "opus",
      "description": "Build fixed-point with x86 SIMD disabled; emscripten requires -msimd128 for SSE/AVX intrinsics.",
      "cmakeOptions": [
        "-DOPUS_FIXED_POINT=ON",
        "-DOPUS_X86_MAY_HAVE_SSE=OFF",
        "-DOPUS_X86_MAY_HAVE_SSE2=OFF",
        "-DOPUS_X86_MAY_HAVE_SSE4_1=OFF",
        "-DOPUS_X86_MAY_HAVE_AVX=OFF",
        "-DOPUS_X86_MAY_HAVE_AVX2=OFF"
      ]
    }
  ],
  "configureFlags": [
    "--target-os=none",
    "--arch=x86_32",
    "--enable-cross-compile",
    "--nm=emnm",
    "--ar=emar",
